# .env.example — copy ไฟล์นี้แล้วเปลี่ยนชื่อเป็น .env (แต่ไม่ต้อง commit)
# วิธีใช้ใน terminal:
#   export TYPHOON_API_KEY="sk-xxx..."
#   export HF_TOKEN="hf_xxx..."
# หรือถ้าต้องการตั้งค่าถาวรให้เพิ่มใน ~/.zshrc:
#   echo 'export TYPHOON_API_KEY="sk-xxx..."' >> ~/.zshrc
#   echo 'export HF_TOKEN="hf_xxx..."' >> ~/.zshrc
#   source ~/.zshrc

# ⚠️  อย่าใส่ค่าจริงในไฟล์นี้! ใช้ export ใน terminal แทน
TYPHOON_API_KEY="sk-xxx...ใส่คีย์จริงที่นี่..."
HF_TOKEN="hf_xxx...ใส่ token ที่นี่..."
